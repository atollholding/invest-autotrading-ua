{
  "name": "invest-autotrading-ua",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "manifest": "node scripts/build-manifest.mjs",
    "documents:orphans": "node scripts/check-document-orphans.mjs",
    "documents:clean-orphans": "node scripts/check-document-orphans.mjs --clean",
    "build": "node scripts/build-manifest.mjs && node scripts/check-document-orphans.mjs && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "node scripts/build-manifest.mjs --verify && node scripts/check-document-orphans.mjs && ASTRO_TELEMETRY_DISABLED=1 astro check"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jura": "^5.2.7",
    "astro": "^6.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^6.0.3"
  }
}
